{
  "name": "playwright-ui-server",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "description": "Visual Playwright test automation builder — see your Playwright tests as interactive flowcharts. Install in any Playwright project and run `npx playwright-ui-server` to launch the UI.",
  "bin": {
    "playwright-ui-server": "./bin/playwright-server.js"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @playwright-server/core run build",
    "build:server": "pnpm --filter @playwright-server/server run build",
    "build:ui": "pnpm --filter @playwright-server/ui run build",
    "bundle": "node scripts/bundle.mjs",
    "prepublishOnly": "node scripts/bundle.mjs",
    "start": "node bin/playwright-server.js",
    "test": "pnpm -r run test"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "keywords": [
    "playwright",
    "testing",
    "automation",
    "visual",
    "drag-and-drop",
    "test-builder",
    "flowchart",
    "test-visualization",
    "e2e"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/merugaJS/playwright-ui-server.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "ts-morph": "^24.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "esbuild": "^0.21.5"
  }
}
